# ==========================================
# RGPV Student Result Management System
# Environment Configuration Template
# ==========================================
# NOTE: Copy this file to .env and fill in your values
# IMPORTANT: .env should NEVER be committed to git

# ==========================================
# Flask Configuration
# ==========================================
# Set to 'development' for local development, 'production' for deployment
FLASK_ENV=development

# Enable Flask debugger (MUST be False in production)
FLASK_DEBUG=False

# Flask app entry point
FLASK_APP=app.py

# ==========================================
# Security Settings
# ==========================================
# Generate a strong secret key with: python -c "import secrets; print(secrets.token_hex(32))"
# CRITICAL: Change this in production!
SECRET_KEY=your-super-secret-key-change-this-to-random-string-in-production

# ==========================================
# Server Configuration
# ==========================================
# IP address to bind to
# 127.0.0.1 = localhost only (development)
# 0.0.0.0 = all network interfaces (production)
HOST=0.0.0.0

# Port number
# Ports 1024 and above don't require root/admin privileges
PORT=5000

# Allowed hosts (comma-separated)
# Used to restrict which domains can access your API
ALLOWED_HOSTS=localhost,127.0.0.1,example.com,www.example.com

# ==========================================
# Database Configuration
# ==========================================
# Database URL for the application
# SQLite: sqlite:///data.db (development)
# PostgreSQL: postgresql://user:password@host:port/dbname (production)
# MySQL: mysql+pymysql://user:password@host:port/dbname (production)
DATABASE_URL=sqlite:///data.db

# Database backup path
DB_BACKUP_PATH=data/backups

# ==========================================
# API Configuration
# ==========================================
# Maximum JSON payload size (in bytes)
MAX_CONTENT_LENGTH=16777216  # 16MB

# Request timeout (in seconds)
REQUEST_TIMEOUT=30

# ==========================================
# Logging Configuration
# ==========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# Maximum log file size before rotation (in bytes)
LOG_MAX_SIZE=10485760  # 10MB

# Number of backup log files to keep
LOG_BACKUP_COUNT=10

# ==========================================
# Email Configuration (Optional)
# ==========================================
# For sending error notifications
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
ADMIN_EMAIL=admin@example.com

# ==========================================
# External APIs (If any)
# ==========================================
# API_KEY=your-api-key-here
# API_SECRET=your-api-secret-here
# EXTERNAL_API_URL=https://api.example.com

# ==========================================
# Monitoring & Analytics (Optional)
# ==========================================
# Sentry error tracking
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Google Analytics
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# ==========================================
# Development Settings (Remove in Production)
# ==========================================
# Enable CORS for all origins in development only
# CORS_ALLOW_ALL=False

# Number of database query retries
DB_RETRY_COUNT=3

# Database retry delay (in seconds)
DB_RETRY_DELAY=1
